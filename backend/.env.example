# ============================================================
# BACKEND ENVIRONMENT EXAMPLE — EC2 + MongoDB Atlas
# Copy to .env and fill in real values before deploying.
# ============================================================

# Django core
SECRET_KEY=your-strong-secret-key-here
DEBUG=False

# EC2: add your public IP and/or domain (comma separated)
# Example: ALLOWED_HOSTS=54.123.45.67,yourdomain.com,localhost
ALLOWED_HOSTS=your-ec2-public-ip,localhost

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/alloy_db

# Frontend origin — EC2 IP:port or domain serving the React build
CORS_ALLOWED_ORIGINS=http://your-ec2-public-ip:3000
CSRF_TRUSTED_ORIGINS=http://your-ec2-public-ip:3000

# Groq AI API key
GROQ_API_KEY=your-groq-api-key-here

# DB init helper (run once to verify Atlas, then set to False)
CREATE_TEST_DB=False
