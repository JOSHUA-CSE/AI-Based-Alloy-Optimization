# ============================================================
# FRONTEND ENVIRONMENT EXAMPLE — EC2 deployment
# Copy to .env and fill in your EC2 backend address.
# ============================================================

# Point this at your EC2 backend (Gunicorn on port 8000)
# Example: REACT_APP_API_URL=http://54.123.45.67:8000/api/
REACT_APP_API_URL=http://your-ec2-public-ip:8000/api/
