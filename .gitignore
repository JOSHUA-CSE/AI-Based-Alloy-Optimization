# ============================================================
# .gitignore — EC2 deployment, MongoDB Atlas, React + Django
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/

# --- Django ---
*.sqlite3
*.sqlite
/backend/staticfiles/
/backend/media/
/backend/static/

# --- Environment files (NEVER commit real secrets) ---
.env
.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local

# --- Node / React ---
node_modules/
/frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
/frontend/coverage/

# --- ML artifacts (large binary files — regenerate from train.py) ---
# Comment these out if you want to commit pre-trained artifacts
# backend/predictor/ml/model.pkl
# backend/predictor/ml/scaler.pkl
# backend/predictor/ml/columns.pkl
# backend/predictor/ml/pipeline_artifacts.pkl

# --- Training data (do not deploy) ---
backend/Alloys.csv

# --- OS ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- IDEs ---
.vscode/
.idea/

# --- Logs ---
*.log
logs/
